# Copy to .env for local use. Never commit .env.
PORT=8787
NODE_ENV=development
DATA_FILE=./data/store.json
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Admin operations require this token in production:
# Authorization: Bearer change-this-long-random-admin-token
ADMIN_TOKEN=change-this-long-random-admin-token

# Merchant API operations require this token for creating and reading orders.
MERCHANT_TOKEN=change-this-long-random-merchant-token

# Used to sign outgoing merchant webhooks with HMAC-SHA256.
WEBHOOK_SECRET=change-this-long-random-webhook-secret

# Optional default merchant webhook target.
DEFAULT_WEBHOOK_URL=

# Public checkout page copy. Use a URL that browsers can load, or leave blank
# and show your collection code manually beside the screen.
PAYMENT_QR_IMAGE_URL=
PAYMENT_ACCOUNT_LABEL=Your Alipay account display name
PAYMENT_INSTRUCTIONS=Open Alipay, scan the collection code, pay the exact amount, and put the order number in the payment note.

# Keep false in production. Enable only for local tests that target 127.0.0.1.
ALLOW_PRIVATE_WEBHOOKS=false

# Token for the simulate provider endpoint. Keep disabled in production unless needed.
SIMULATE_PROVIDER_TOKEN=change-this-simulate-provider-token
